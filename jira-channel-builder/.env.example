# Jira Cloud 網址（不含尾端斜線）
# 範例：https://your-company.atlassian.net
JIRA_BASE_URL=https://your-company.atlassian.net

# Jira 帳號 Email（用於 API Basic Auth）
JIRA_EMAIL=your-email@example.com

# Jira API Token（不是密碼）
# 取得方式：https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=your_jira_api_token_here

# 本地 webhook 監聽埠
PORT=8789

# webhook 路徑
WEBHOOK_PATH=/webhook/jira

# webhook 保護 token（建議設定）
# Jira Webhook URL 可加上 ?token=your_secret
WEBHOOK_SECRET=change_this_secret

# 允許的 Jira 事件（逗號分隔）
JIRA_ALLOWED_EVENTS=jira:issue_created,jira:issue_updated

# 限定專案 key（逗號分隔，空值代表不限制）
ALLOWED_PROJECT_KEYS=DEMO

# 限定 issue 狀態（空值代表不限制）
REQUIRED_STATUS=Ready

# 收到 webhook 後，先轉成此狀態避免重複處理（留空可關閉）
CLAIM_STATUS=In Progress

# Claude 回覆 reply(status=Done) 時轉移到的狀態（留空可關閉）
DONE_STATUS=Done

# Claude 回覆 reply(status=Failed) 時轉移到的狀態（留空可關閉）
FAILED_STATUS=To Do
