# Slack Bot Token (OAuth token for your Slack App)
# 取得方式：https://api.slack.com/apps → 選擇 App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack App-Level Token (for Socket Mode)
# 取得方式：https://api.slack.com/apps → 選擇 App → Basic Information → App-Level Tokens → 建立 Token (connections:write scope)
SLACK_APP_TOKEN=xapp-your-app-level-token-here

# 允許觸發 Claude 的 Slack User ID（逗號分隔）
# 取得方式：Slack → 個人資料 → 更多 → 複製 Member ID
ALLOWED_USER_IDS=U000000000,U111111111
