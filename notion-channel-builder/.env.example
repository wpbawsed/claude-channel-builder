# Notion Integration Token
# 取得方式：https://www.notion.so/my-integrations → 建立 Integration → 複製 Internal Integration Token
NOTION_API_KEY=ntn_your_notion_integration_token_here

# Notion Database ID
# 取得方式：開啟目標 Database 頁面 → 複製 URL 中的 32 碼 ID
# 範例：https://notion.so/workspace/373314f6c3a8...  → 373314f6c3a84c5b8195d6093f8d45c0
NOTION_DATABASE_ID=your_32_char_database_id_here
